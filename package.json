{
  "name": "qa-demowebshop-playwright",
  "version": "1.0.0",
  "description": "UI automation framework for Demo Web Shop using Playwright + TypeScript.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report:html": "playwright show-report",
    "report:allure": "allure generate ./allure-results --clean -o ./allure-report && allure open ./allure-report"
  },
  "keywords": [],
  "author": "Waqas",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.4.2",
    "dotenv": "^17.2.3"
  }
}
